# --- 実行ユーザー設定 ---
# ホストのユーザーIDとグループIDを指定します (id -u, id -g で確認可能)
PUID=1000
PGID=1000

# --- トンネル設定 (tcpexposer) ---
# https://<ここに入れた名前>.tcpexposer.com でアクセス可能になります
# ホストPCでSSHキーを作成してください
# tcpexposerでアカウント作成後、SSH公開鍵・サブドメイン登録を行ってください
SSH_SECRET_KEY_FILENAME="id_ed25519"
SUBDOMAIN="your-subdomain"
TCPEXPOSER_USERNAME="your-tcpexposer-username"

# --- バックアップ設定 ---
# バックアップの間隔（秒） - デフォルト 86400 (24時間)
BACKUP_INTERVAL_SECONDS=86400
# 何日分のバックアップを保持するか
BACKUP_RETENTION_DAYS=7

# --- SQLD サーバー設定 ---
SQLD_NODE="primary"

# --- クライアント (Next.js) 用メモ ---
# 生成したトークンをここにメモしておくと便利です
# DATABASE_AUTH_TOKEN=""
